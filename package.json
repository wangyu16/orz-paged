{
  "name": "orz-paged",
  "version": "0.5.0",
  "description": "Self-contained, editable HTML documents (.paged.html) — Markdown shown as print pages via paged.js, edited in-browser, exported to PDF by printing. Sibling of orz-mdhtml and orz-slides.",
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "bin": {
    "orz-paged": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "orz-paged-skills"
  ],
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "tsx build/bundle.ts",
    "gen": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "paged",
    "pagedjs",
    "print",
    "pdf",
    "orz-markdown",
    "markdown",
    "self-contained",
    "single-file"
  ],
  "author": "Yu Wang <yuwang@orz.how>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangyu16/orz-paged"
  },
  "dependencies": {
    "orz-markdown": "^1.3.2",
    "pagedjs": "^0.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.21.5",
    "path-browserify": "^1.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
