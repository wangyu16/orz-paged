{
  "name": "orz-paged",
  "version": "0.7.3",
  "description": "Single-file, self-editing Markdown documents laid out as print-ready pages and exported to PDF from the browser.",
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "bin": {
    "orz-paged": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "orz-paged-skills"
  ],
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "tsx build/bundle.ts",
    "gen": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "paged",
    "pagedjs",
    "print",
    "pdf",
    "orz-markdown",
    "markdown",
    "self-contained",
    "single-file"
  ],
  "author": "Yu Wang <yuwang@orz.how>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangyu16/orz-paged.git"
  },
  "homepage": "https://markdown.orz.how/family.html#paged",
  "bugs": "https://github.com/wangyu16/orz-paged/issues",
  "dependencies": {
    "orz-markdown": "^1.6.3",
    "pagedjs": "^0.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.28.1",
    "path-browserify": "^1.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
